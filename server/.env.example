YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE
# Recommended default for Ghughuti AI (speed + low cost)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-5-mini
# Optional: auto-retry on OpenAI if the primary model is unavailable
OPENAI_FALLBACK_MODEL=gpt-4.1-mini

# Google OAuth Client ID (for Ghughuti AI login)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Optional fallbacks
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
# OpenRouter — used as the LLM fallback when Groq is unavailable / rate-limited
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_REFERER=https://garhwali-stream.onrender.com
PORT=5000
CLIENT_URL=http://localhost:5173

# ElevenLabs TTS — used for the "Listen" button in Ghughuti AI
# Get your API key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
# Voice ID to use (default: Adam multilingual). Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Model (default: eleven_multilingual_v2 — best for Hindi/Garhwali)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
