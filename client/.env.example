# Google OAuth Client ID for Ghughuti AI login
# Get yours at: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized JavaScript origins: http://localhost:5173, https://yourdomain.com
# 3. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ElevenLabs TTS — called directly from the browser (free tier requires real user IPs)
# Get your API key at https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
# Voice ID (default: Adam multilingual). Browse at https://elevenlabs.io/voice-library
VITE_ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Model: eleven_turbo_v2_5 is free-tier compatible
VITE_ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
